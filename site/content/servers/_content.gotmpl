{{/* Content adapter: generate one Details page per server from the catalog. */}}
{{ $cat := site.Data.catalog }}
{{ range $id, $s := $cat.servers }}
  {{ if not $s.hidden }}
    {{ $.AddPage (dict
      "path"   $id
      "kind"   "page"
      "title"  $s.title
      "params" $s
    ) }}
  {{ end }}
{{ end }}
